{
  "name": "hola-boss-oss",
  "private": true,
  "packageManager": "bun@1.3.6",
  "workspaces": [
    "apps/desktop",
    "runtime/api-server",
    "runtime/harness-host",
    "runtime/harnesses",
    "runtime/state-store",
    "sdk/app-builder-sdk",
    "sdk/app-sdk",
    "sdk/editor",
    "sdk/runtime-client",
    "website/docs"
  ],
  "trustedDependencies": [
    "@electron/rebuild",
    "@parcel/watcher",
    "better-sqlite3",
    "electron",
    "electron-builder",
    "esbuild"
  ],
  "scripts": {
    "clean": "node scripts/remove-paths.mjs out apps/desktop/build runtime/out",
    "dev": "bun run desktop:dev",
    "docs:dev": "bun --filter=docs-next run dev",
    "docs:test": "bun --filter=docs-next run test",
    "docs:typecheck": "bun --filter=docs-next run typecheck",
    "docs:build": "bun --filter=docs-next run build",
    "docs:preview": "bun --filter=docs-next run preview",
    "docs:deploy:staging": "bun --filter=docs-next run deploy:staging",
    "docs:deploy:production": "bun --filter=docs-next run deploy:production",
    "desktop:clean": "node scripts/remove-paths.mjs apps/desktop/out apps/desktop/build",
    "desktop:install": "bun install",
    "desktop:prepare": "bun --filter=@holaboss/app-sdk run build",
    "desktop:dev": "bun --filter=holaboss-local run dev",
    "desktop:e2e": "bun --filter=holaboss-local run e2e",
    "desktop:typecheck": "bun --filter=holaboss-local run typecheck",
    "desktop:prepare-runtime": "bun --filter=holaboss-local run prepare:runtime",
    "desktop:prepare-runtime:local": "bun --filter=holaboss-local run prepare:runtime:local",
    "desktop:dist:mac:local": "bun --filter=holaboss-local run dist:mac:local",
    "desktop:dist:win:local": "bun --filter=holaboss-local run dist:win:local",
    "runtime:harnesses:install": "bun install",
    "runtime:harness-host:install": "bun install",
    "runtime:harness-host:build": "bun --filter=@holaboss/runtime-harness-host run build",
    "runtime:harness-host:test": "bun --filter=@holaboss/runtime-harness-host run test",
    "runtime:harness-host:typecheck": "bun --filter=@holaboss/runtime-harness-host run typecheck",
    "runtime:state-store:install": "bun install",
    "runtime:state-store:build": "bun --filter=@holaboss/runtime-state-store run build",
    "runtime:state-store:test": "bun --filter=@holaboss/runtime-state-store run test",
    "runtime:state-store:typecheck": "bun --filter=@holaboss/runtime-state-store run typecheck",
    "runtime:api-server:install": "bun install",
    "runtime:api-server:build": "bun --filter=@holaboss/runtime-api-server run build",
    "runtime:api-server:test": "bun --filter=@holaboss/runtime-api-server run test",
    "runtime:api-server:typecheck": "bun --filter=@holaboss/runtime-api-server run typecheck",
    "runtime:clean": "node scripts/remove-paths.mjs out/runtime-linux out/runtime-macos out/runtime-windows out/runtime-root runtime/out",
    "runtime:test": "bun --filter=@holaboss/runtime-state-store run test && bun --filter=@holaboss/runtime-harness-host run test && bun --filter=@holaboss/runtime-api-server run test",
    "sdk:app-sdk:install": "bun install",
    "sdk:app-sdk:build": "bun --filter=@holaboss/app-sdk run build",
    "sdk:app-sdk:test": "bun --filter=@holaboss/app-sdk run test",
    "sdk:app-sdk:typecheck": "bun --filter=@holaboss/app-sdk run typecheck",
    "sdk:app-sdk:codegen": "bun --filter=@holaboss/app-sdk run codegen"
  }
}
